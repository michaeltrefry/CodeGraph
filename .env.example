ASPNETCORE_ENVIRONMENT=Development

CodeGraph__TsPort=3100

CodeGraph__StorageOptions__Provider=MariaDb
CodeGraph__StorageOptions__MariaDbConnectionString=Server=mariadb;Port=3306;Database=codegraph;User ID=codegraph;Password=codegraph_test!;
CodeGraph__StorageOptions__MariaDbMigrationsPath=/app/sql/migrations
CodeGraph__StorageOptions__MariaDbEncryptionKey=
CodeGraph__StorageOptions__EmbeddingModelName=all-MiniLM-L6-v2
CodeGraph__StorageOptions__EmbeddingModelPath=/models/embeddings/all-MiniLM-L6-v2/model.onnx

CodeGraph__RabbitMqOptions__Host=rabbitmq
CodeGraph__RabbitMqOptions__Username=guest
CodeGraph__RabbitMqOptions__Password=guest

CodeGraph__RepositorySource__Provider=Folder
CodeGraph__RepositorySource__ReposCachePath=/repos/.cache
CodeGraph__RepositorySource__Folder__RootPath=/repos
CodeGraph__RepositorySource__GitLab__BaseUrl=https://gitlab.example.com/
CodeGraph__RepositorySource__GitLab__PrivateToken=
CodeGraph__RepositorySource__GitHub__BaseUrl=https://api.github.com
CodeGraph__RepositorySource__GitHub__PersonalAccessToken=
CodeGraph__RepositorySource__GitHub__Organization=

CodeGraph__AnalysisOptions__DefaultProvider=local
CodeGraph__AnalysisOptions__Model=claude-sonnet-4-6
CodeGraph__AnalysisOptions__ApiKey=
CodeGraph__AnalysisOptions__Assistant__Provider=local
CodeGraph__AnalysisOptions__Assistant__Model=
CodeGraph__AnalysisOptions__Assistant__MaxTokens=10000
CodeGraph__AnalysisOptions__Assistant__MaxTurns=10
CodeGraph__AnalysisOptions__Assistant__Anthropic__ApiKey=
CodeGraph__AnalysisOptions__Assistant__Anthropic__BaseUrl=
CodeGraph__AnalysisOptions__Assistant__OpenAi__ApiKey=
CodeGraph__AnalysisOptions__Assistant__OpenAi__BaseUrl=
CodeGraph__AnalysisOptions__Assistant__OpenAi__ChatCompletionsPath=
CodeGraph__AnalysisOptions__Assistant__OpenAi__Organization=
CodeGraph__AnalysisOptions__Assistant__OpenAi__Project=
CodeGraph__AnalysisOptions__Assistant__Local__ApiKey=
CodeGraph__AnalysisOptions__Assistant__Local__BaseUrl=http://host.docker.internal:1234/v1
CodeGraph__AnalysisOptions__Assistant__Local__ChatCompletionsPath=/chat/completions
CodeGraph__AnalysisOptions__OpenAi__ApiKey=
CodeGraph__AnalysisOptions__OpenAi__BaseUrl=https://api.openai.com/v1
CodeGraph__AnalysisOptions__OpenAi__Model=gpt-5
CodeGraph__AnalysisOptions__Gemini__ApiKey=
CodeGraph__AnalysisOptions__Gemini__BaseUrl=https://generativelanguage.googleapis.com/v1beta
CodeGraph__AnalysisOptions__Gemini__Model=gemini-2.5-flash
CodeGraph__AnalysisOptions__Local__ApiKey=
CodeGraph__AnalysisOptions__Local__BaseUrl=http://host.docker.internal:1234/v1
CodeGraph__AnalysisOptions__Local__Model=
CodeGraph__AnalysisOptions__Local__TimeoutSeconds=300
CodeGraph__AnalysisOptions__Local__MaxConcurrentRequests=1
CodeGraph__AnalysisOptions__Local__DirectFallbackMaxAttempts=3
CodeGraph__AnalysisOptions__Local__UseJsonObjectResponseFormat=false
CodeGraph__AnalysisOptions__Local__MaxSourceChars=32000
CodeGraph__AnalysisOptions__Local__MaxPromptNodes=80
CodeGraph__AnalysisOptions__Local__MaxRelationshipTargetsPerType=8

CodeGraph__McpOptions__RequirePersonalAccessToken=false

CodeGraph__AuthOptions__Enabled=false
CodeGraph__AuthOptions__Authority=
CodeGraph__AuthOptions__Audience=codegraph-api
CodeGraph__AuthOptions__ClientId=codegraph-web
CodeGraph__AuthOptions__Scope=openid profile email
CodeGraph__AuthOptions__AuthorizationUrl=
CodeGraph__AuthOptions__TokenUrl=
CodeGraph__AuthOptions__EndSessionUrl=
CodeGraph__AuthOptions__AllowedOrigins__0=https://codegraph.trefry.net
CodeGraph__AuthOptions__RequireHttpsMetadata=true
CodeGraph__AuthOptions__LocalDevUsername=local-admin
CodeGraph__AuthOptions__LocalDevIsAdmin=true

# Public trefry.net deployment:
# CodeGraph__AuthOptions__Enabled=true
# CodeGraph__AuthOptions__Authority=https://identity.trefry.net/realms/trefry
# CodeGraph__AuthOptions__Audience=codegraph-api
# CodeGraph__AuthOptions__ClientId=codegraph-web
# CodeGraph__AuthOptions__Scope=openid profile email
# CodeGraph__AuthOptions__AuthorizationUrl=https://identity.trefry.net/realms/trefry/protocol/openid-connect/auth
# CodeGraph__AuthOptions__TokenUrl=https://identity.trefry.net/realms/trefry/protocol/openid-connect/token
# CodeGraph__AuthOptions__EndSessionUrl=https://identity.trefry.net/realms/trefry/protocol/openid-connect/logout
# CodeGraph__AuthOptions__AllowedOrigins__0=https://codegraph.trefry.net
# CodeGraph__McpOptions__RequirePersonalAccessToken=true

CODEGRAPH_DOCKER_MODELS_MOUNT=./.cache/models
CODEGRAPH_DOCKER_LEGACY_MODELS_MOUNT=../llm/models
CODEGRAPH_DOCKER_REPOS_MOUNT=../
CODEGRAPH_DOCKER_HTTPS_PORT=8443
CODEGRAPH_DOCKER_TLS_CERT_PATH=./CodeGraphWeb/certs/localhost.pem
CODEGRAPH_DOCKER_TLS_KEY_PATH=./CodeGraphWeb/certs/localhost-key.pem
