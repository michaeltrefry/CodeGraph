{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CodeGraph": {
    "TsPort": 3100,
    "InternalServiceAuth": {
      "Enabled": false,
      "HmacKey": "",
      "Issuer": "codegraph",
      "TokenLifetimeSeconds": 60,
      "ClockSkewSeconds": 30
    },
    "StorageOptions": {
      "Provider": "MariaDb",
      "BatchSize": 500,
      "MariaDbConnectionString": "Server=localhost;Port=3306;Database=codegraph;User ID=codegraph;Password=codegraph_test!;",
      "MariaDbMigrationsPath": "sql/migrations",
      "MariaDbEncryptionKey": "",
      "Neo4jUri": "bolt://localhost:7687",
      "Neo4jUsername": "neo4j",
      "Neo4jPassword": "",
      "Neo4jMigrationsPath": "Migrations",
      "EmbeddingDimensions": 384,
      "EmbeddingModelName": "all-MiniLM-L6-v2"
    },
    "AnalysisOptions": {
      "DefaultProvider": "anthropic",
      "Model": "claude-sonnet-4-6",
      "ApiKey": "",
      "OpenAi": {
        "ApiKey": "",
        "BaseUrl": "https://api.openai.com/v1",
        "ChatCompletionsPath": "/chat/completions",
        "BatchesPath": "/batches",
        "FilesPath": "/files",
        "Model": "gpt-5",
        "Organization": "",
        "Project": ""
      },
      "LmStudio": {
        "ApiKey": "",
        "BaseUrl": "http://localhost:1234/v1",
        "ChatCompletionsPath": "/chat/completions",
        "Model": "qwen3",
        "TimeoutSeconds": 600,
        "MaxConcurrentRequests": 1,
        "DirectFallbackMaxAttempts": 3,
        "UseJsonObjectResponseFormat": false,
        "MaxSourceChars": 32000,
        "MaxPromptNodes": 80,
        "MaxRelationshipTargetsPerType": 8
      },
      "AutoCommitDocs": true,
      "AutoPushDocs": true,
      "AutoCommitMessage": "docs(codegraph): update CODEGRAPH.md",
      "AutoCommitAuthorName": "CodeGraph",
      "AutoCommitAuthorEmail": "codegraph@localhost"
    },
    "IndexingOptions": {
      "MaxParallelFiles": 8,
      "MaxParallelRepos": 1,
      "DetectCommunitiesAfterIndexing": false,
      "FoundationalRepos": []
    },
    "RepositorySource": {
      "Provider": "Folder",
      "ReposCachePath": "~/repos/.cache",
      "ExcludedGroups": [],
      "GitLab": {
        "BaseUrl": "https://gitlab.example.com/",
        "PrivateToken": ""
      },
      "GitHub": {
        "BaseUrl": "https://api.github.com",
        "PersonalAccessToken": "",
        "Organization": ""
      },
      "Folder": {
        "RootPath": "~/repos/"
      }
    },
    "RabbitMqOptions": {
      "Host": "localhost",
      "Username": "guest",
      "Password": "guest"
    },
    "ConsumerOptions": {
      "ConsumerRetryLimit": 3,
      "ConsumerRetryInitialInterval": 1000,
      "ConsumerRetryIntervalIncrement": 1000
    }
  }
}
