{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ModelContextProtocol": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CodeGraph": {
    "TsPort": 3100,
    "StorageOptions": {
      "BatchSize": 500,
      "Neo4jUri": "bolt://localhost:7687",
      "Neo4jUsername": "neo4j",
      "Neo4jPassword": "",
      "Neo4jMigrationsPath": "Migrations",
      "EmbeddingDimensions": 384,
      "EmbeddingModelName": "all-MiniLM-L6-v2"
    },
    "AnalysisOptions": {
      "DefaultProvider": "anthropic",
      "Model": "claude-sonnet-4-6",
      "ApiKey": "",
      "OpenAi": {
        "ApiKey": "",
        "BaseUrl": "https://api.openai.com/v1",
        "ChatCompletionsPath": "/chat/completions",
        "BatchesPath": "/batches",
        "FilesPath": "/files",
        "Model": "gpt-5",
        "Organization": "",
        "Project": ""
      },
      "Gemini": {
        "ApiKey": "",
        "BaseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "Model": "gemini-2.5-flash"
      },
      "Local": {
        "ApiKey": "",
        "BaseUrl": "http://localhost:1234/v1",
        "ChatCompletionsPath": "/chat/completions",
        "Model": "qwen3",
        "UseJsonObjectResponseFormat": false
      },
      "AutoCommitDocs": false,
      "AutoPushDocs": false,
      "AutoCommitMessage": "docs(codegraph): update CODEGRAPH.md"
    },
    "IndexingOptions": {
      "MaxParallelFiles": 8,
      "DetectCommunitiesAfterIndexing": false,
      "FoundationalRepos": []
    },
    "RepositorySource": {
      "Provider": "Folder",
      "ReposCachePath": "~/repos/.cache",
      "ExcludedGroups": [],
      "GitLab": {
        "BaseUrl": "https://gitlab.example.com/",
        "PrivateToken": ""
      },
      "GitHub": {
        "BaseUrl": "https://api.github.com",
        "PersonalAccessToken": "",
        "Organization": ""
      },
      "Folder": {
        "RootPath": "~/repos/"
      }
    },
    "RabbitMqOptions": {
      "Host": "localhost",
      "Username": "guest",
      "Password": "guest"
    },
    "ConsumerOptions": {
      "ConsumerRetryLimit": 3,
      "ConsumerRetryInitialInterval": 1000,
      "ConsumerRetryIntervalIncrement": 1000
    },
    "WikiOptions": {
      "MaxAttachmentSizeMb": 10,
      "AttachmentStoragePath": "uploads/wiki"
    }
  }
}
