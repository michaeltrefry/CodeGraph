{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "ModelContextProtocol": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CodeGraph": "Server=localhost;Database=codegraph;User=root;Password=;SslMode=None"
  },
  "CodeGraph": {
    "TsPort": 3100,
    "StorageOptions": {
      "BatchSize": 500,
      "Neo4jUri": "bolt://localhost:7687",
      "Neo4jUsername": "neo4j",
      "Neo4jPassword": "",
      "Neo4jMigrationsPath": "cypher/migrations",
      "EmbeddingDimensions": 384,
      "EmbeddingModelName": "all-MiniLM-L6-v2"
    },
    "AnalysisOptions": {
      "Model": "claude-sonnet-4-6",
      "ApiKey": ""
    },
    "IndexingOptions": {
      "MaxParallelFiles": 8,
      "FoundationalRepos": [ "TC.Common.ServiceStack", "TC.Common.ServiceBus", "TC.Common.Models" ]
    },
    "RepositorySource": {
      "Provider": "GitLab",
      "ReposCachePath": "D:\\repos\\cache",
      "ExcludedGroups": [ "old-svn-repos", "utilities", "mysql.utilities" ],
      "GitLab": {
        "BaseUrl": "https://gitlab.tcdevops.com/",
        "PrivateToken": ""
      },
      "GitHub": {
        "BaseUrl": "https://api.github.com",
        "PersonalAccessToken": "",
        "Organization": ""
      },
      "Folder": {
        "RootPath": ""
      }
    },
    "RabbitMqOptions": {
      "Host": "localhost",
      "Username": "guest",
      "Password": "guest"
    },
    "ConsumerOptions": {
      "ConsumerRetryLimit": 3,
      "ConsumerRetryInitialInterval": 1000,
      "ConsumerRetryIntervalIncrement": 1000
    },
    "WikiOptions": {
      "MaxAttachmentSizeMb": 10,
      "AttachmentStoragePath": "uploads/wiki"
    },
    "AuthOptions": {
      "AuthorizationUrl": "https://stgauth.tcdevops.com/connect/authorize",
      "TokenUrl": "https://stgauth.tcdevops.com/connect/token",
      "ClientId": "codegraph-web",
      "Authority": "https://stgauth.tcdevops.com"
    }
  }
}
